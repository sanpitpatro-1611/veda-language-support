{
  
  "name": "VEDA",
  "scopeName": "source.veda",

  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#numbers" },
    { "include": "#strings" }
  ],

  "repository": {

    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.veda",
          "match": "#.*$"
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.veda",
          "match": "\\b(say|remember|ask|if|otherwise|action|do|change|calculate|repeat)\\b"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.veda",
          "match": "\\b(greater than or equals|less than or equals|greater than|less than|equals|not equals)\\b"
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.veda",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.veda",
          "begin": "\"",
          "end": "\""
        }
      ]
    }

  }
}